{
  "manifest_version": 3,
  "name": "ASS-CEE 28jun26",
  "author": "PhongChillFansub",
  "version": "0.0.0.5",
  "description": "Hiển thị phụ đề Aegisub trên YouTube",
  "permissions": ["storage", "activeTab", "scripting", "unlimitedStorage"],
  "optional_host_permissions": [
    "https://www.youtube.com/*",
    "https://www.bilibili.tv/*",
    "https://www.bilibili.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://*.usercontent.google.com/*",
    "https://www.googleapis.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "minimum_chrome_version": "102",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": { 
    "default_title": "[PhongChillFansub] ASS-CEE. Click để kích hoạt phụ đề cho trang này"
  },
  "content_scripts": [{
    "matches": ["https://www.youtube.com/watch?v=*"],
    "js": [
      "content/ui.js",
      "content/renderer.js"
    ],
    "css": [
      "content/ui.css"
    ],
    "all_frames": true,
    "run_at": "document_idle"
  }]
}