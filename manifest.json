{
  "manifest_version": 3,
  "name": "ASS-CEE 21jun26",
  "author": "PhongChillFansub",
  "version": "0.0.0.3",
  "description": "Hiển thị phụ đề Aegisub trên YouTube",
  "permissions": ["storage", "activeTab", "scripting", "unlimitedStorage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://*.usercontent.google.com/*",
    "https://www.googleapis.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": { 
    "default_title": "[PhongChillFansub] ASS-CEE. Click để kích hoạt phụ đề cho trang này"
  },
  "content_scripts": [{
    "matches": ["https://www.youtube.com/watch?v=*"],
    "js": [
      "content/ui.js"
    ],
    "css": [
      "content/ui.css"
    ],
    "run_at": "document_idle"
  }]
}